ANTHROPIC_API_KEY=
OPENAI_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Set to "true" to enable POST /sms webhook handling (default is disabled)
ENABLE_TWILIO_SMS=false
PORT=1807

# CORS (comma-separated origins). If unset, localhost origins are allowed.
# CORS_ALLOWED_ORIGINS=https://rioedwards.com,https://www.rioedwards.com

# Express trust proxy. Defaults to 1 in production, false otherwise.
# TRUST_PROXY=1

# Session memory cleanup (optional, defaults are built in)
# SESSION_TTL_MS=86400000
# SESSION_CLEANUP_INTERVAL_MS=300000

# Provider request timeout in milliseconds (optional, default shown)
# PROVIDER_TIMEOUT_MS=15000

# Graceful shutdown wait before force exit in milliseconds
# SHUTDOWN_GRACE_MS=10000

# Redis-backed rate limiter (optional, falls back to memory if unavailable)
# REDIS_URL=redis://localhost:6379
# REDIS_CONNECT_TIMEOUT_MS=2000

# Rate limiting (optional, sensible defaults are built in)
# RATE_LIMIT_IP_MAX=30
# RATE_LIMIT_IP_WINDOW_MS=3600000
# RATE_LIMIT_SESSION_MAX=20
# RATE_LIMIT_SESSION_WINDOW_MS=3600000

# Set to "false" to disable OpenAI fallback
# FALLBACK_ENABLED=true

# Input limits (optional, sensible defaults are built in)
# MAX_MESSAGE_LENGTH=1000
# MAX_HISTORY_TURNS=20
