ANTHROPIC_API_KEY=
OPENAI_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
PORT=1807

# CORS (comma-separated origins). If unset, localhost origins are allowed.
# CORS_ALLOWED_ORIGINS=https://rioedwards.com,https://www.rioedwards.com

# Express trust proxy. Defaults to 1 in production, false otherwise.
# TRUST_PROXY=1

# Rate limiting (optional, sensible defaults are built in)
# RATE_LIMIT_IP_MAX=30
# RATE_LIMIT_IP_WINDOW_MS=3600000
# RATE_LIMIT_SESSION_MAX=20
# RATE_LIMIT_SESSION_WINDOW_MS=3600000

# Set to "false" to disable OpenAI fallback
# FALLBACK_ENABLED=true

# Input limits (optional, sensible defaults are built in)
# MAX_MESSAGE_LENGTH=1000
# MAX_HISTORY_TURNS=20
